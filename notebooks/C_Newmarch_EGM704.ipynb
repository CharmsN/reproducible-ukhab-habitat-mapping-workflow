    "import joblib\n",
    "import pandas as pd\n",
    "\n",
    "# Load the trained Random Forest model\n",
    "model = joblib.load(r\"C:\\EGM704\\data_sets\\egm704_project\\data\\sites\\models\\rf_model_desb_wick_2024.joblib\")   # adjust path if needed\n",
    "\n",
